local function createHighlightTemplate()
    local template = Instance.new("Highlight")
    template.FillColor = Color3.fromRGB(0, 255, 0)
    template.FillTransparency = 0.5
    template.OutlineColor = Color3.fromRGB(0, 0, 0)
    template.OutlineTransparency = 0
    template.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    return template
end

local templateHighlight = createHighlightTemplate()

