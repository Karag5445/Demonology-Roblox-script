local Tab1 = Window:CreateTab("Main", 7539983773)
local Section = Tab1:CreateSection("Section with functions")

local ghostHighlight = nil
local GhostESP = Tab1:CreateToggle({
    Name = "Ghost ESP",
    CurrentValue = false,
    Flag = "GhostESP",
    Callback = function(Value)
        local ghost = workspace:FindFirstChild("Ghost")
        if not ghost then
            Rayfield:Notify({
                Title = "Error",
                Content = "Ghost not found!",
                Duration = 3
            })
            return
        end
        
        if Value then
            if not ghostHighlight then
                ghostHighlight = templateHighlight:Clone()
                ghostHighlight.Parent = ghost
            end
            ghostHighlight.FillColor = Color3.fromRGB(255, 0, 0)
            ghostHighlight.FillTransparency = 0.5
            ghostHighlight.OutlineTransparency = 0
            
            if ghost:FindFirstChild("ZoneCheckPart") then
                ghost.ZoneCheckPart.Transparency = 0
            end
            if ghost:FindFirstChild("Head") then
                ghost.Head.Transparency = 0
            end
            
            Rayfield:Notify({
                Title = "Console",
                Content = "Ghost ESP ✅",
                Duration = 3
            })
        else
            if ghostHighlight then
                ghostHighlight.FillTransparency = 1
                ghostHighlight.OutlineTransparency = 1
            end
            Rayfield:Notify({
                Title = "Console",
                Content = "Ghost ESP ❌",
                Duration = 3
            })
        end
    end,
})
local itemHighlights = {}
local ItemsESP = Tab1:CreateToggle({
    Name = "Items ESP",
    CurrentValue = false,
    Flag = "ItemsESP",
    Callback = function(Value)
        local itemsFolder = workspace:FindFirstChild("Items")
        if not itemsFolder then
            Rayfield:Notify({
                Title = "Error",
                Content = "Items folder not found!",
                Duration = 3
            })
            return
        end
        
        local items = itemsFolder:GetChildren()
        
        if Value then
            for _, item in ipairs(items) do
                if item and not itemHighlights[item] then
                    local copyItems = templateHighlight:Clone()
                    copyItems.Parent = item
                    itemHighlights[item] = copyItems
                    copyItems.FillTransparency = 0.5
                    copyItems.OutlineTransparency = 0
                elseif itemHighlights[item] then
                    itemHighlights[item].FillTransparency = 0.5
                    itemHighlights[item].OutlineTransparency = 0
                end
            end
            Rayfield:Notify({
                Title = "Console",
                Content = "Item ESP ✅",
                Duration = 3
            })
        else
            for _, highlight in pairs(itemHighlights) do
                highlight.FillTransparency = 1
                highlight.OutlineTransparency = 1
            end
            Rayfield:Notify({
                Title = "Console",
                Content = "Item ESP ❌",
                Duration = 3
            })
        end
    end,
})

